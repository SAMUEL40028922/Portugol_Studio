programa
{
	
	funcao inicio()
	{
		 inteiro numero 

		 escreva(" insira um numero positivo maior que 0:")
		 leia(numero)

	enquanto( numero >= 0) {
		
	      escreva(numero + " | ")	
	      numero = numero - 1

	}

	escreva("fim!")


	      
		}
		
		
		
	
}
