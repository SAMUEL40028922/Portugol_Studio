programa
{
	
	funcao inicio()
	{
		inteiro num1,result	
		
		escreva (" digite um número inteiro:"+  "")
		leia(num1)

		se (num1 % 5 == 0){
			escreva ("seu número e multiplo de 5 " + "")}

		senao{

			escreva("o número " + num1 + " não é multiplo de 5 ")
		}
		
		
		
		
		
	}
}
