programa
{
	
	funcao inicio()
	{
		cadeia frutas[5] = {"Banana","maçã","Abacate","morango","Maracujá"}

		escreva("========== Armazenamento ==========\n")

		para(inteiro posicao = 0; posicao <=4; posicao++){
			escreva(" # " + posicao)
			escreva(" " + frutas[posicao] + "\n")
			
		}
	}
}
