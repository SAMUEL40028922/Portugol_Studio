programa
{
	
	funcao inicio()
	{
		logico fases[5] = {verdadeiro , falso , falso , falso , verdadeiro}

			para(inteiro posicao = 0; posicao <=4; posicao++){	
				escreva("fase " + posicao + " concluido: " + fases[posicao] + "\n" )	
			}
				
				
				
			
			
			

		
	}
}
